#!/usr/bin/env bash

echo "Run .claude-code"

mkdir -p ~/.claude

# Symlink configuration files
ln -sf "$HOME/.dotfiles/home/claude/CLAUDE.md" ~/.claude/CLAUDE.md
ln -sf "$HOME/.dotfiles/home/claude/settings.json" ~/.claude/settings.json
ln -sf "$HOME/.dotfiles/home/claude/statusline.sh" ~/.claude/statusline.sh

# Symlink entire skills directory
rm -rf ~/.claude/skills
ln -sf "$HOME/.dotfiles/home/claude/skills" ~/.claude/skills

# Symlink entire agents directory
rm -rf ~/.claude/agents
ln -sf "$HOME/.dotfiles/home/claude/agents" ~/.claude/agents

# Marketplaces
claude plugin marketplace add laravel/claude-code
claude plugin marketplace add JuliusBrussee/caveman

# Plugins
claude plugin install caveman@caveman
claude plugin install chrome-devtools-mcp@claude-plugins-official
claude plugin install context7@claude-plugins-official
claude plugin install frontend-design@claude-plugins-official
claude plugin install laravel-simplifier@laravel
claude plugin install playwright@claude-plugins-official
claude plugin install security-guidance@claude-plugins-official
claude plugin install skill-creator@claude-plugins-official
claude plugin install superpowers@claude-plugins-official